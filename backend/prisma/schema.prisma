// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Multi-Tenant Models
// ============================================

model Tenant {
  id                    Int                @id @default(autoincrement())
  name                  String
  slug                  String             @unique
  customDomain          String?            @unique
  logo                  String?
  logoInitials          String?            @default("CL")
  primaryColor          String             @default("#0F766E")
  accentColor           String             @default("#F59E0B")
  ownerName             String?
  contactEmail          String
  contactPhone          String?
  address               String?
  website               String?
  plan                  TenantPlan         @default(FREE)
  subscriptionStatus    SubscriptionStatus @default(TRIAL)
  subscriptionStartAt   DateTime?
  subscriptionEndsAt    DateTime?
  trialEndsAt           DateTime?
  maxStudents           Int                @default(50)
  maxBatches            Int                @default(3)
  maxTeachers           Int                @default(2)
  maxStorageMB          Int                @default(500)
  featureQRAttendance   Boolean            @default(true)
  featureAssignments    Boolean            @default(false)
  featureFees           Boolean            @default(false)
  featureStudyMaterials Boolean            @default(false)
  featureAnnouncements  Boolean            @default(true)
  featureVideos         Boolean            @default(false)
  teacherPermissions    Json               @default("{\"canManageLectures\":true,\"canUploadNotes\":true,\"canUploadVideos\":false,\"canManageAssignments\":true,\"canViewFees\":false,\"canManageStudyMaterials\":false,\"canSendAnnouncements\":true,\"canViewAnalytics\":false,\"canExportData\":false}")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  suspendedAt           DateTime?
  deletedAt             DateTime?
  suspendedReason       String?

  // Back-references
  users               User[]
  students            Student[]
  batches             Batch[]
  attendances         Attendance[]
  attendanceSheets    AttendanceSheet[]
  qrAttendanceTokens  QRAttendanceToken[]
  youtubeVideos       YoutubeVideo[]
  notes               Note[]
  assignmentSlots     AssignmentSlot[]
  studentSubmissions  StudentSubmission[]
  announcements       Announcement[]
  studyMaterials      StudyMaterial[]
  feeStructures       FeeStructure[]
  feeReceipts         FeeReceipt[]
  loginAttempts       LoginAttempt[]
  lectures            Lecture[]
  tests               Test[]
  testScores          TestScore[]
  notifPreferences    NotificationPreference[]
  quotaOverride       TenantQuotaOverride?
  configs             TenantConfig[]

  @@index([slug])
  @@index([customDomain])
  @@index([subscriptionStatus])
  @@map("tenants")
}

model TenantQuotaOverride {
  id                    Int       @id @default(autoincrement())
  tenantId              Int       @unique
  tenant                Tenant    @relation(fields: [tenantId], references: [id])
  maxStudents           Int?
  maxBatches            Int?
  maxTeachers           Int?
  maxStorageMB          Int?
  featureAssignments    Boolean?
  featureFees           Boolean?
  featureStudyMaterials Boolean?
  featureAnnouncements  Boolean?
  featureVideos         Boolean?
  featureQRAttendance   Boolean?
  overrideReason        String?
  overriddenBy          Int
  overriddenAt          DateTime  @default(now())
  expiresAt             DateTime?

  @@map("tenant_quota_overrides")
}

model TenantConfig {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  key         String
  value       String
  isSecret    Boolean  @default(false)
  category    String
  description String?
  updatedBy   Int?
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("tenant_config")
}

// ============================================
// New Enums
// ============================================

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
  EXPIRED
}

// ============================================
// Existing Models — updated with tenantId
// ============================================

model User {
  id                  Int       @id @default(autoincrement())
  tenantId            Int?
  tenant              Tenant?   @relation(fields: [tenantId], references: [id])
  name                String
  email               String
  password            String?
  role                UserRoles @default(STUDENT)
  isPasswordSet       Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  updatedAt            DateTime?            @updatedAt
  createdAt            DateTime?            @default(now())
  passwordResetTokens  PasswordResetToken[]
  student              Student?
  lectures             Lecture[]            @relation("TeacherLectures")
  teacherAssignments   AssignmentSlot[]     @relation("TeacherAssignments")
  teacherMaterials     StudyMaterial[]      @relation("TeacherMaterials")
  teacherTests         Test[]               @relation("TeacherTests")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Student {
  id         Int      @id @default(autoincrement())
  tenantId   Int?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  firstname  String
  middlename String
  lastname   String
  fullname   String
  email      String
  dob        String
  batchId    Int?
  batch      Batch?   @relation(fields: [batchId], references: [id])
  userId     Int?     @unique
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  attendance Json?
  address    String?
  phone       String?
  parentName  String?
  grade       String?
  instituteId String?
  isDeleted  Boolean? @default(false)
  deletedBy  String?

  updatedAt               DateTime?              @updatedAt
  createdAt               DateTime?              @default(now())
  attendances             Attendance[]
  submissions             StudentSubmission[]
  feeReceipts             FeeReceipt[]
  testScores              TestScore[]
  notificationPreference  NotificationPreference?

  @@unique([tenantId, email])
  @@index([batchId])
  @@index([userId])
  @@index([tenantId])
  @@map("students")
}

model Batch {
  id            Int      @id @default(autoincrement())
  tenantId      Int?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  name          String
  totalStudents Json?
  timings       Json?
  isDeleted     Boolean? @default(false)
  deletedBy     String?

  students           Student[]
  sheets             AttendanceSheet[]
  qrAttendanceTokens QRAttendanceToken[]
  assignmentSlots    AssignmentSlot[]
  studyMaterials     StudyMaterial[]
  feeStructures      FeeStructure[]
  feeReceipts        FeeReceipt[]
  lectures           Lecture[]
  tests              Test[]

  updatedAt   DateTime?    @updatedAt
  createdAt   DateTime?    @default(now())
  attendances Attendance[]

  @@index([tenantId])
  @@map("batches")
}

model QRAttendanceToken {
  id        Int      @id @default(autoincrement())
  tenantId  Int?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  batchId   Int
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  token     String
  date      DateTime @db.Date
  expiresAt DateTime
  isActive  Boolean  @default(true)

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([tenantId, batchId, date])
  @@index([batchId, date])
  @@index([token])
  @@index([tenantId])
  @@map("qr_attendance_tokens")
}

model AttendanceSheet {
  id         Int          @id @default(autoincrement())
  tenantId   Int?
  tenant     Tenant?      @relation(fields: [tenantId], references: [id])
  batchId    Int
  batch      Batch        @relation(fields: [batchId], references: [id])
  month      String
  year       String
  attendance Attendance[]

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([tenantId, batchId, year, month])
  @@index([batchId, year, month])
  @@index([tenantId])
  @@map("attendance_sheets")
}

model Attendance {
  id         Int              @id @default(autoincrement())
  tenantId   Int?
  tenant     Tenant?          @relation(fields: [tenantId], references: [id])
  studentId  Int
  student    Student          @relation(fields: [studentId], references: [id])
  batchId    Int
  batch      Batch            @relation(fields: [batchId], references: [id])
  date       DateTime         @default(now())
  time       String?
  markedBy   String?
  markedById Int?
  method     AttendanceMethod @default(MANUAL)
  status     AttendanceStatus @default(ABSENT)

  reason    String?
  lectureId Int?
  lecture   Lecture?  @relation(fields: [lectureId], references: [id])

  attendanceSheet   AttendanceSheet? @relation(fields: [attendanceSheetId], references: [id])
  attendanceSheetId Int?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([tenantId, studentId, date, batchId])
  @@index([studentId, date])
  @@index([batchId, date])
  @@index([attendanceSheetId])
  @@index([lectureId])
  @@index([tenantId])
  @@map("attendances")
}

model YoutubeVideo {
  id          Int                     @id @default(autoincrement())
  tenantId    Int?
  tenant      Tenant?                 @relation(fields: [tenantId], references: [id])
  title       String
  description String?
  url         String                  @unique
  visibility  YoutubeVideoVisibility? @default(PRIVATE)
  category    String?
  batchId     Int
  isDeleted   Boolean?                @default(false)
  deletedBy   String?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@index([tenantId])
  @@map("youtube_videos")
}

model Note {
  id        Int      @id @default(autoincrement())
  tenantId  Int?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  title     String
  content   String[]
  batchId   Int
  category  String?
  isDeleted Boolean? @default(false)
  deletedBy String?
  deletedAt DateTime?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@index([tenantId])
  @@map("notes")
}

model AssignmentSlot {
  id          Int              @id @default(autoincrement())
  tenantId    Int?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  title       String
  subject     String
  description String?
  attachments Json?            // Array of { url, publicId, originalFilename, size, mimeType }
  batchId     Int
  batch       Batch            @relation(fields: [batchId], references: [id])
  teacherId   Int?
  teacher     User?            @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: SetNull)
  groupId     String?          // Links multi-batch assignment sets (same groupId = same assignment)

  // Assignment settings
  submissionType       SubmissionType   @default(FILE_UPLOAD)
  assignmentStatus     AssignmentStatus @default(PUBLISHED)
  allowLateSubmissions Boolean          @default(false)
  plagiarismCheck      Boolean          @default(false)

  dueDate     DateTime?
  createdBy   String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  isDeleted   Boolean          @default(false)
  deletedBy   String?

  submissions StudentSubmission[]

  @@index([batchId])
  @@index([teacherId])
  @@index([groupId])
  @@index([assignmentStatus, isDeleted])
  @@index([tenantId])
  @@map("assignment_slots")
}

model StudentSubmission {
  id          Int              @id @default(autoincrement())
  tenantId    Int?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id])
  slotId      Int
  slot        AssignmentSlot   @relation(fields: [slotId], references: [id])
  studentId   Int
  student     Student          @relation(fields: [studentId], references: [id])
  files       Json             // Array of { url, publicId, originalFilename, size, mimeType }
  note        String?          // Optional text note from student with submission
  status      SubmissionStatus @default(PENDING)
  feedback    String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, slotId, studentId])
  @@index([slotId])
  @@index([studentId])
  @@index([tenantId])
  @@map("student_submissions")
}

model Announcement {
  id          Int                  @id @default(autoincrement())
  tenantId    Int?
  tenant      Tenant?              @relation(fields: [tenantId], references: [id])
  title       String
  description String               // Short preview text
  body        String?              // Full rich-text content shown in detail view
  imageUrl    String?
  date        DateTime?
  category    AnnouncementCategory @default(GENERAL)
  priority    AnnouncementPriority @default(NORMAL)
  department  String?              // e.g., "Admin Office", "Mathematics Dept"
  attachments Json?                // Array of { url, filename, size, mimeType }
  metadata    Json?                // Structured key-value e.g., { "Start Date": "June 1st, 2026" }
  isActive    Boolean              @default(true)
  createdBy   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([category, isActive])
  @@index([isActive, createdAt])
  @@index([tenantId])
  @@map("announcements")
}

model StudyMaterial {
  id          Int               @id @default(autoincrement())
  tenantId    Int?
  tenant      Tenant?           @relation(fields: [tenantId], references: [id])
  title       String
  description String?
  files       Json              // Array of { url, publicId, originalFilename, size, mimeType }
  batchId     Int
  batch       Batch             @relation(fields: [batchId], references: [id])
  teacherId   Int?
  teacher     User?             @relation("TeacherMaterials", fields: [teacherId], references: [id], onDelete: SetNull)

  // Classification
  category        String?
  subject         String?
  chapter         String?
  materialType    StudyMaterialType @default(DOCUMENT)

  // Status & Scheduling
  materialStatus  MaterialStatus    @default(PUBLISHED)
  scheduledAt     DateTime?         // Only relevant when materialStatus = SCHEDULED

  // Multi-class visibility (besides primary batchId)
  visibleBatchIds Int[]             // Additional batch IDs that can view this material

  createdBy   String
  isDeleted   Boolean           @default(false)
  deletedBy   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([batchId])
  @@index([teacherId])
  @@index([materialStatus, isDeleted])
  @@index([materialType])
  @@index([tenantId])
  @@map("study_materials")
}

model FeeStructure {
  id          Int          @id @default(autoincrement())
  tenantId    Int?
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  batchId     Int
  batch       Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name        String       // e.g., "Monthly Tuition Fee", "Lab Fee"
  amount      Float
  frequency   FeeFrequency @default(MONTHLY)
  dueDay      Int          @default(5) // Day of month when fee is due
  lateFee     Float        @default(0)
  gracePeriod Int          @default(5) // Days after late fee applies
  isActive    Boolean      @default(true)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts FeeReceipt[]

  @@unique([tenantId, batchId, name])
  @@index([batchId])
  @@index([tenantId])
  @@map("fee_structures")
}

model FeeReceipt {
  id              Int           @id @default(autoincrement())
  tenantId        Int?
  tenant          Tenant?       @relation(fields: [tenantId], references: [id])
  receiptNumber   String        @unique // Format: RCP-{tenantSlug}-YYYY-NNNNN
  studentId       Int
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batchId         Int
  batch           Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  feeStructureId  Int?
  feeStructure    FeeStructure? @relation(fields: [feeStructureId], references: [id], onDelete: SetNull)

  // Amount Details
  totalAmount     Float
  paidAmount      Float         @default(0)
  discountAmount  Float         @default(0)
  lateFeeAmount   Float         @default(0)
  remainingAmount Float         @default(0)

  // Payment Details
  paymentMode     PaymentMode?
  transactionId   String?
  chequeNumber    String?
  bankName        String?
  paymentNotes    String?

  // Period
  academicMonth   Int
  academicYear    Int

  // Status
  status          PaymentStatus @default(PENDING)

  // Dates
  dueDate         DateTime
  paymentDate     DateTime?

  // Audit
  generatedBy     String
  generatedById   Int?
  modifiedBy      String?
  modifiedById    Int?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([studentId])
  @@index([batchId])
  @@index([status])
  @@index([academicMonth, academicYear])
  @@index([dueDate])
  @@index([tenantId])
  @@map("fee_receipts")
}

model NotificationPreference {
  id        Int     @id @default(autoincrement())
  tenantId  Int?
  tenant    Tenant? @relation(fields: [tenantId], references: [id])
  studentId Int     @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  // Academic Alerts
  classStartingSoon    Boolean @default(true)
  timetableChanges     Boolean @default(true)

  // Exams & Results
  newTestScheduled     Boolean @default(true)
  resultPublished      Boolean @default(true)

  // Materials & Updates
  newStudyMaterial     Boolean @default(true)
  classResourceUploaded Boolean @default(false)

  // Administrative
  schoolAnnouncements  Boolean @default(true)
  doubtResponses       Boolean @default(true)

  // Quiet Hours
  quietHoursEnabled    Boolean @default(false)
  quietHoursFrom       String  @default("22:00")
  quietHoursTo         String  @default("07:00")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("notification_preferences")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  tenantId  Int?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  email     String?
  ipAddress String
  success   Boolean
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([tenantId])
  @@map("login_attempts")
}

model Lecture {
  id            Int           @id @default(autoincrement())
  tenantId      Int?
  tenant        Tenant?       @relation(fields: [tenantId], references: [id])
  title         String
  subject       String
  description   String?
  room          String?
  batchId       Int
  batch         Batch         @relation(fields: [batchId], references: [id])
  teacherId     Int?
  teacher       User?         @relation("TeacherLectures", fields: [teacherId], references: [id])
  assignedBy    String?

  // Schedule
  date          DateTime
  startTime     String
  endTime       String
  duration      Int

  // Status
  status        LectureStatus @default(SCHEDULED)
  notes         String?

  // Recurrence
  recurrenceId  String?

  // Audit
  createdBy     Int
  isDeleted     Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  attendances   Attendance[]

  @@index([batchId])
  @@index([teacherId])
  @@index([date])
  @@index([batchId, date])
  @@index([tenantId])
  @@map("lectures")
}

model Test {
  id            Int        @id @default(autoincrement())
  tenantId      Int?
  tenant        Tenant?    @relation(fields: [tenantId], references: [id])
  title         String
  subject       String
  description   String?
  testType      TestType   @default(UNIT_TEST)
  batchId       Int
  batch         Batch      @relation(fields: [batchId], references: [id])

  // Scoring
  totalMarks    Float
  passingMarks  Float?

  // Schedule
  date          DateTime
  time          String?
  duration      Int?
  hall          String?

  // Content
  syllabus      String?
  instructions  String?

  // Status
  status        TestStatus @default(DRAFT)
  publishedAt   DateTime?
  scoresLocked  Boolean    @default(false)

  // Teacher
  teacherId     Int?
  teacher       User?      @relation("TeacherTests", fields: [teacherId], references: [id], onDelete: SetNull)

  // Relations
  scores        TestScore[]

  // Audit
  createdBy     Int
  isDeleted     Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([batchId])
  @@index([teacherId])
  @@index([batchId, date])
  @@index([status, isDeleted])
  @@index([tenantId])
  @@map("tests")
}

model TestScore {
  id            Int         @id @default(autoincrement())
  tenantId      Int?
  tenant        Tenant?     @relation(fields: [tenantId], references: [id])
  testId        Int
  test          Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  studentId     Int
  student       Student     @relation(fields: [studentId], references: [id])

  // Score
  marksObtained Float
  percentage    Float
  grade         String?
  status        ScoreStatus @default(PASS)

  // Feedback
  remarks       String?

  // Who uploaded
  uploadedBy    Int

  // Audit
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([testId, studentId])
  @@index([testId])
  @@index([studentId])
  @@index([tenantId])
  @@map("test_scores")
}

// ============================================
// Auth Models (global — not tenant-scoped in $extends)
// ============================================

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model TokenBlacklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([token])
  @@map("token_blacklist")
}

// ============================================
// Enums (existing)
// ============================================

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AnnouncementCategory {
  GENERAL
  EXAM
  HOLIDAY
  LECTURE
  EVENT
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SubmissionType {
  FILE_UPLOAD
  TEXT_ENTRY
  BOTH
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
}

enum StudyMaterialType {
  DOCUMENT
  VIDEO
  NOTES
  SLIDES
  WORKSHEET
}

enum MaterialStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum UserRoles {
  ADMIN
  TEACHER
  STUDENT
}

enum AttendanceMethod {
  MANUAL
  QR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum YoutubeVideoVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

// ============================================
// Fee Management Enums
// ============================================

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  ONE_TIME
}

// ============================================
// Lectures Enums
// ============================================

enum LectureStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ============================================
// Tests & Scores Enums
// ============================================

enum TestType {
  UNIT_TEST
  MIDTERM
  FINAL
  QUIZ
  PRACTICE
}

enum TestStatus {
  DRAFT
  SCHEDULED
  ONGOING
  COMPLETED
  PUBLISHED
}

enum ScoreStatus {
  PASS
  FAIL
  ABSENT
}

// ============================================
// Instagram Automation System (not tenant-scoped)
// ============================================

model InstagramAccount {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  igUserId          String   @unique
  username          String
  profilePictureUrl String?
  accessToken       String
  tokenExpiresAt    DateTime?
  followersCount    Int?
  mediaCount        Int?

  automationRules AutomationRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("instagram_accounts")
}

model AutomationRule {
  id                 Int                  @id @default(autoincrement())
  instagramAccountId Int
  instagramAccount   InstagramAccount     @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  mediaId            String
  mediaUrl           String?
  mediaCaption       String?
  mediaType          String?
  triggerKeyword     String
  dmMessage          String
  dmType             DmType               @default(TEXT)
  dmButtons          Json?
  status             AutomationRuleStatus @default(ACTIVE)
  dmsSentCount       Int                  @default(0)
  isFollowGated      Boolean              @default(false)
  unfollowedMessage  String?
  lastTriggeredAt    DateTime?

  logs AutomationLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instagramAccountId])
  @@index([mediaId])
  @@index([instagramAccountId, mediaId, triggerKeyword])
  @@map("automation_rules")
}

model AutomationLog {
  id               Int            @id @default(autoincrement())
  ruleId           Int
  rule             AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  commenterId      String
  commenterUsername String?
  commentText      String
  dmStatus         DmStatus       @default(SENT)
  errorMessage     String?

  createdAt DateTime @default(now())

  @@index([ruleId])
  @@index([commenterId])
  @@map("automation_logs")
}

enum AutomationRuleStatus {
  ACTIVE
  PAUSED
}

enum DmStatus {
  SENT
  FAILED
  RATE_LIMITED
}

enum DmType {
  TEXT
  TEMPLATE
}
