// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int       @id @default(autoincrement())
  name                String
  email               String    @unique
  password            String
  role                UserRoles @default(STUDENT)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  updatedAt            DateTime?            @updatedAt
  createdAt            DateTime?            @default(now())
  passwordResetTokens  PasswordResetToken[]

  @@map("users")
}

model Student {
  id         Int      @id @default(autoincrement())
  firstname  String
  middlename String
  lastname   String
  fullname   String
  email      String   @unique
  dob        String
  batchId    Int?
  batch      Batch?   @relation(fields: [batchId], references: [id])
  attendance Json?
  address    String?
  isDeleted  Boolean? @default(false)
  deletedBy  String?

  updatedAt   DateTime?           @updatedAt
  createdAt   DateTime?           @default(now())
  attendances Attendance[]
  submissions StudentSubmission[]
  feeReceipts FeeReceipt[]

  @@index([batchId])
  @@map("students")
}

model Batch {
  id            Int      @id @default(autoincrement())
  name          String
  totalStudents Json?
  timings       Json?
  isDeleted     Boolean? @default(false)
  deletedBy     String?

  students           Student[]
  sheets             AttendanceSheet[]
  qrAttendanceTokens QRAttendanceToken[]
  assignmentSlots    AssignmentSlot[]
  studyMaterials     StudyMaterial[]
  feeStructures      FeeStructure[]
  feeReceipts        FeeReceipt[]

  updatedAt   DateTime?    @updatedAt
  createdAt   DateTime?    @default(now())
  attendances Attendance[]

  @@map("batches")
}

model QRAttendanceToken {
  id        Int      @id @default(autoincrement())
  batchId   Int
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  token     String
  date      DateTime @db.Date
  expiresAt DateTime
  isActive  Boolean  @default(true)

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([batchId, date])
  @@index([batchId, date])
  @@index([token])
  @@map("qr_attendance_tokens")
}

model AttendanceSheet {
  id         Int          @id @default(autoincrement())
  batchId    Int
  batch      Batch        @relation(fields: [batchId], references: [id])
  month      String
  year       String
  attendance Attendance[]

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([batchId, year, month])
  @@index([batchId, year, month])
  @@map("attendance_sheets")
}

model Attendance {
  id         Int              @id @default(autoincrement())
  studentId  Int
  student    Student          @relation(fields: [studentId], references: [id])
  batchId    Int
  batch      Batch            @relation(fields: [batchId], references: [id])
  date       DateTime         @default(now())
  time       String?
  markedBy   String?
  markedById Int?
  method     AttendanceMethod @default(MANUAL)
  status     AttendanceStatus @default(ABSENT)

  attendanceSheet   AttendanceSheet? @relation(fields: [attendanceSheetId], references: [id])
  attendanceSheetId Int?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([studentId, date, batchId])
  @@index([studentId, date])
  @@index([batchId, date])
  @@index([attendanceSheetId])
  @@map("attendances")
}

model YoutubeVideo {
  id          Int                     @id @default(autoincrement())
  title       String
  description String?
  url         String                  @unique
  visibility  YoutubeVideoVisibility? @default(PRIVATE)
  category    String?
  batchId     Int
  isDeleted   Boolean?                @default(false)
  deletedBy   String?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@map("youtube_videos")
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String[]
  batchId   Int
  category  String?
  isDeleted Boolean? @default(false)
  deletedBy String?
  deletedAt DateTime?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@map("notes")
}

model AssignmentSlot {
  id          Int       @id @default(autoincrement())
  title       String
  subject     String
  description String?
  batchId     Int
  batch       Batch     @relation(fields: [batchId], references: [id])
  dueDate     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  isDeleted   Boolean   @default(false)

  submissions StudentSubmission[]

  @@index([batchId])
  @@map("assignment_slots")
}

model StudentSubmission {
  id          Int              @id @default(autoincrement())
  slotId      Int
  slot        AssignmentSlot   @relation(fields: [slotId], references: [id])
  studentId   Int
  student     Student          @relation(fields: [studentId], references: [id])
  files       Json             // Array of file URLs
  status      SubmissionStatus @default(PENDING)
  feedback    String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([slotId, studentId])
  @@index([slotId])
  @@index([studentId])
  @@map("student_submissions")
}

model Announcement {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  date        DateTime?
  priority    AnnouncementPriority @default(NORMAL)
  isActive    Boolean   @default(true)
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("announcements")
}

model StudyMaterial {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  files       Json     // Array of file URLs
  batchId     Int
  batch       Batch    @relation(fields: [batchId], references: [id])
  category    String?
  createdBy   String
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([batchId])
  @@map("study_materials")
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum UserRoles {
  ADMIN
  TEACHER
  STUDENT
}

enum AttendanceMethod {
  MANUAL
  QR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum YoutubeVideoVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

// ============================================
// Fee Management Enums & Models
// ============================================

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  ONE_TIME
}

model FeeStructure {
  id          Int          @id @default(autoincrement())
  batchId     Int
  batch       Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name        String       // e.g., "Monthly Tuition Fee", "Lab Fee"
  amount      Float
  frequency   FeeFrequency @default(MONTHLY)
  dueDay      Int          @default(5) // Day of month when fee is due
  lateFee     Float        @default(0)
  gracePeriod Int          @default(5) // Days after due date before late fee applies
  isActive    Boolean      @default(true)
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts FeeReceipt[]

  @@unique([batchId, name])
  @@index([batchId])
  @@map("fee_structures")
}

model FeeReceipt {
  id              Int           @id @default(autoincrement())
  receiptNumber   String        @unique // Format: RCP-YYYY-NNNNN
  studentId       Int
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batchId         Int
  batch           Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  feeStructureId  Int?
  feeStructure    FeeStructure? @relation(fields: [feeStructureId], references: [id], onDelete: SetNull)

  // Amount Details
  totalAmount     Float
  paidAmount      Float         @default(0)
  discountAmount  Float         @default(0)
  lateFeeAmount   Float         @default(0)
  remainingAmount Float         @default(0) // Computed: totalAmount - paidAmount - discountAmount + lateFeeAmount

  // Payment Details
  paymentMode     PaymentMode?
  transactionId   String?       // For digital payments
  chequeNumber    String?
  bankName        String?
  paymentNotes    String?

  // Period
  academicMonth   Int           // 1-12
  academicYear    Int           // e.g., 2024

  // Status
  status          PaymentStatus @default(PENDING)

  // Dates
  dueDate         DateTime
  paymentDate     DateTime?

  // Audit
  generatedBy     String        // Admin who generated
  generatedById   Int?
  modifiedBy      String?
  modifiedById    Int?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([studentId])
  @@index([batchId])
  @@index([status])
  @@index([academicMonth, academicYear])
  @@index([dueDate])
  @@map("fee_receipts")
}

// ============================================
// Student Authentication Models
// ============================================

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model TokenBlacklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([token])
  @@map("token_blacklist")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String?
  ipAddress String
  success   Boolean
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}
