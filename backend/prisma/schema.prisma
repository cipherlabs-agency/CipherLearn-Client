generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                  @id @default(autoincrement())
  name                String
  email               String               @unique
  password            String?
  role                UserRoles            @default(STUDENT)
  updatedAt           DateTime?            @updatedAt
  createdAt           DateTime?            @default(now())
  failedLoginAttempts Int                  @default(0)
  lockedUntil         DateTime?
  isPasswordSet       Boolean              @default(false)
  teacherAssignments  AssignmentSlot[]     @relation("TeacherAssignments")
  deviceTokens        DeviceToken[]
  doubtReplies        DoubtReply[]
  instagramAccount    InstagramAccount?
  lectures            Lecture[]            @relation("TeacherLectures")
  notifications       Notification[]       @relation("UserNotifications")
  passwordResetTokens PasswordResetToken[]
  student             Student?
  teacherMaterials    StudyMaterial[]      @relation("TeacherMaterials")
  teacherProfile      TeacherProfile?
  teacherTests        Test[]               @relation("TeacherTests")

  @@map("users")
}

model Student {
  id                     Int                     @id @default(autoincrement())
  firstname              String
  middlename             String
  lastname               String
  fullname               String
  email                  String                  @unique
  dob                    String
  batchId                Int?
  address                String?
  isDeleted              Boolean?                @default(false)
  deletedBy              String?
  updatedAt              DateTime?               @updatedAt
  createdAt              DateTime?               @default(now())
  userId                 Int?                    @unique
  grade                  String?
  instituteId            String?
  parentName             String?
  phone                  String?
  avatarUrl              String?
  attendances            Attendance[]
  doubts                 Doubt[]
  feeReceipts            FeeReceipt[]
  notificationPreference NotificationPreference?
  starredResources       ResourceStar[]
  submissions            StudentSubmission[]
  batch                  Batch?                  @relation(fields: [batchId], references: [id])
  user                   User?                   @relation(fields: [userId], references: [id])
  testScores             TestScore[]

  @@index([batchId])
  @@index([userId])
  @@index([batchId, isDeleted])
  @@index([isDeleted, createdAt])
  @@map("students")
}

model Batch {
  id                 Int                 @id @default(autoincrement())
  name               String
  timings            Json?
  isDeleted          Boolean?            @default(false)
  deletedBy          String?
  updatedAt          DateTime?           @updatedAt
  createdAt          DateTime?           @default(now())
  totalStudents      Json?
  assignmentSlots    AssignmentSlot[]
  sheets             AttendanceSheet[]
  attendances        Attendance[]
  doubts             Doubt[]
  feeReceipts        FeeReceipt[]
  feeStructures      FeeStructure[]
  lectures           Lecture[]
  materialFolders    MaterialFolder[]
  notes              Note[]
  qrAttendanceTokens QRAttendanceToken[]
  students           Student[]
  studyMaterials     StudyMaterial[]
  tests              Test[]
  youtubeVideos      YoutubeVideo[]
  landingPage        LandingPage?
  leads              Lead[]

  @@map("batches")
}

model LandingPage {
  id          Int      @id @default(autoincrement())
  batchId     Int      @unique
  slug        String   @unique
  config      Json
  theme       Json
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("landing_pages")
}

model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  batchId   Int
  message   String?
  status    String   @default("NEW") // NEW, CONTACTED, CONVERTED, REJECTED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("leads")
}

model QRAttendanceToken {
  id        Int       @id @default(autoincrement())
  batchId   Int
  token     String    @unique
  date      DateTime  @db.Date
  expiresAt DateTime
  isActive  Boolean   @default(true)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  batch     Batch     @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, date])
  @@index([batchId, date])
  @@index([token])
  @@map("qr_attendance_tokens")
}

model AttendanceSheet {
  id         Int          @id @default(autoincrement())
  batchId    Int
  month      String
  year       String
  updatedAt  DateTime?    @updatedAt
  createdAt  DateTime?    @default(now())
  batch      Batch        @relation(fields: [batchId], references: [id])
  attendance Attendance[]

  @@unique([batchId, year, month])
  @@index([batchId, year, month])
  @@map("attendance_sheets")
}

model Attendance {
  id                Int              @id @default(autoincrement())
  studentId         Int
  batchId           Int
  date              DateTime         @default(now())
  time              String?
  markedBy          String?
  markedById        Int?
  method            AttendanceMethod @default(MANUAL)
  status            AttendanceStatus @default(ABSENT)
  attendanceSheetId Int?
  updatedAt         DateTime?        @updatedAt
  createdAt         DateTime?        @default(now())
  lectureId         Int?
  reason            String?
  subject           String?
  attendanceSheet   AttendanceSheet? @relation(fields: [attendanceSheetId], references: [id])
  batch             Batch            @relation(fields: [batchId], references: [id])
  lecture           Lecture?         @relation(fields: [lectureId], references: [id])
  student           Student          @relation(fields: [studentId], references: [id])

  @@unique([studentId, date, batchId])
  @@index([studentId, date])
  @@index([batchId, date])
  @@index([attendanceSheetId])
  @@index([lectureId])
  @@map("attendances")
}

model YoutubeVideo {
  id              Int                     @id @default(autoincrement())
  title           String
  description     String?
  url             String                  @unique
  visibility      YoutubeVideoVisibility? @default(PRIVATE)
  category        String?
  batchId         Int
  isDeleted       Boolean?                @default(false)
  deletedBy       String?
  updatedAt       DateTime?               @updatedAt
  createdAt       DateTime?               @default(now())
  scheduledAt     DateTime?
  subject         String?
  visibleBatchIds Int[]
  batch           Batch                   @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([batchId, isDeleted])
  @@map("youtube_videos")
}

model Note {
  id        Int       @id @default(autoincrement())
  title     String
  content   String[]
  batchId   Int
  category  String?
  isDeleted Boolean?  @default(false)
  deletedBy String?
  deletedAt DateTime?
  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())
  batch     Batch     @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([batchId, isDeleted])
  @@map("notes")
}

model AssignmentSlot {
  id                   Int                 @id @default(autoincrement())
  title                String
  subject              String
  description          String?
  batchId              Int
  dueDate              DateTime?
  createdBy            String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  isDeleted            Boolean             @default(false)
  attachments          Json?
  allowLateSubmissions Boolean             @default(false)
  assignmentStatus     AssignmentStatus    @default(PUBLISHED)
  deletedBy            String?
  groupId              String?
  plagiarismCheck      Boolean             @default(false)
  submissionType       SubmissionType      @default(FILE_UPLOAD)
  teacherId            Int?
  batch                Batch               @relation(fields: [batchId], references: [id])
  teacher              User?               @relation("TeacherAssignments", fields: [teacherId], references: [id])
  submissions          StudentSubmission[]

  @@index([batchId])
  @@index([teacherId])
  @@index([groupId])
  @@index([assignmentStatus, isDeleted])
  @@map("assignment_slots")
}

model StudentSubmission {
  id          Int              @id @default(autoincrement())
  slotId      Int
  studentId   Int
  files       Json
  status      SubmissionStatus @default(PENDING)
  feedback    String?
  reviewedBy  String?
  reviewedAt  DateTime?
  submittedAt DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  note        String?
  slot        AssignmentSlot   @relation(fields: [slotId], references: [id])
  student     Student          @relation(fields: [studentId], references: [id])

  @@unique([slotId, studentId])
  @@index([slotId])
  @@index([studentId])
  @@index([studentId, status])
  @@map("student_submissions")
}

model Announcement {
  id             Int                  @id @default(autoincrement())
  title          String
  description    String
  imageUrl       String?
  date           DateTime?
  priority       AnnouncementPriority @default(NORMAL)
  isActive       Boolean              @default(true)
  createdBy      String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  attachments    Json?
  body           String?
  category       AnnouncementCategory @default(GENERAL)
  department     String?
  metadata       Json?
  createdById    Int?
  pinned         Boolean              @default(false)
  isDraft        Boolean              @default(false)
  scheduledAt    DateTime?
  targetBatchIds Int[]

  @@index([category, isActive])
  @@index([isActive, createdAt])
  @@index([isActive, isDraft, scheduledAt])
  @@index([createdById])
  @@map("announcements")
}

model MaterialFolder {
  id        Int             @id @default(autoincrement())
  name      String
  batchId   Int
  createdBy String
  isDeleted Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  batch     Batch           @relation(fields: [batchId], references: [id])
  materials StudyMaterial[]

  @@unique([batchId, name])
  @@index([batchId])
  @@map("material_folders")
}

model StudyMaterial {
  id              Int               @id @default(autoincrement())
  title           String
  description     String?
  files           Json
  batchId         Int
  category        String?
  createdBy       String
  isDeleted       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  chapter         String?
  deletedBy       String?
  materialStatus  MaterialStatus    @default(PUBLISHED)
  materialType    StudyMaterialType @default(DOCUMENT)
  scheduledAt     DateTime?
  subject         String?
  teacherId       Int?
  visibleBatchIds Int[]
  folderId        Int?
  batch           Batch             @relation(fields: [batchId], references: [id])
  folder          MaterialFolder?   @relation(fields: [folderId], references: [id])
  teacher         User?             @relation("TeacherMaterials", fields: [teacherId], references: [id])

  @@index([batchId])
  @@index([teacherId])
  @@index([folderId])
  @@index([materialStatus, isDeleted])
  @@index([materialType])
  @@map("study_materials")
}

model FeeStructure {
  id          Int          @id @default(autoincrement())
  batchId     Int
  name        String
  amount      Float
  frequency   FeeFrequency @default(MONTHLY)
  dueDay      Int          @default(5)
  lateFee     Float        @default(0)
  gracePeriod Int          @default(5)
  isActive    Boolean      @default(true)
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  receipts    FeeReceipt[]
  batch       Batch        @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, name])
  @@index([batchId])
  @@map("fee_structures")
}

model FeeReceipt {
  id              Int           @id @default(autoincrement())
  receiptNumber   String        @unique
  studentId       Int
  batchId         Int
  feeStructureId  Int?
  totalAmount     Float
  paidAmount      Float         @default(0)
  discountAmount  Float         @default(0)
  lateFeeAmount   Float         @default(0)
  remainingAmount Float         @default(0)
  paymentMode     PaymentMode?
  transactionId   String?
  chequeNumber    String?
  bankName        String?
  paymentNotes    String?
  academicMonth   Int
  academicYear    Int
  status          PaymentStatus @default(PENDING)
  dueDate         DateTime
  paymentDate     DateTime?
  generatedBy     String
  generatedById   Int?
  modifiedBy      String?
  modifiedById    Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  batch           Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)
  feeStructure    FeeStructure? @relation(fields: [feeStructureId], references: [id])
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([batchId])
  @@index([status])
  @@index([studentId, status])
  @@index([batchId, academicYear, academicMonth])
  @@index([academicMonth, academicYear])
  @@index([dueDate])
  @@map("fee_receipts")
}

model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  userId    Int
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model TokenBlacklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  reason    String?
  createdAt DateTime @default(now())

  @@index([token])
  @@map("token_blacklist")
}

model NotificationPreference {
  id                    Int      @id @default(autoincrement())
  studentId             Int      @unique
  classStartingSoon     Boolean  @default(true)
  timetableChanges      Boolean  @default(true)
  newTestScheduled      Boolean  @default(true)
  resultPublished       Boolean  @default(true)
  newStudyMaterial      Boolean  @default(true)
  classResourceUploaded Boolean  @default(false)
  schoolAnnouncements   Boolean  @default(true)
  doubtResponses        Boolean  @default(true)
  quietHoursEnabled     Boolean  @default(false)
  quietHoursFrom        String   @default("22:00")
  quietHoursTo          String   @default("07:00")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  student               Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String?
  ipAddress String
  success   Boolean
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@map("login_attempts")
}

model Lecture {
  id           Int           @id @default(autoincrement())
  title        String
  subject      String
  description  String?
  room         String?
  batchId      Int
  teacherId    Int?
  assignedBy   String?
  date         DateTime
  startTime    String
  endTime      String
  duration     Int
  status       LectureStatus @default(SCHEDULED)
  notes        String?
  recurrenceId String?
  createdBy    Int
  isDeleted    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  attachments  Json?
  isOnline     Boolean       @default(false)
  meetingLink  String?
  attendances  Attendance[]
  batch        Batch         @relation(fields: [batchId], references: [id])
  teacher      User?         @relation("TeacherLectures", fields: [teacherId], references: [id])

  @@index([batchId])
  @@index([teacherId])
  @@index([date])
  @@index([batchId, date])
  @@index([batchId, isDeleted, date])
  @@index([teacherId, isDeleted, date])
  @@map("lectures")
}

model Test {
  id           Int            @id @default(autoincrement())
  title        String
  subject      String
  description  String?
  testType     TestType       @default(UNIT_TEST)
  batchId      Int
  totalMarks   Float
  passingMarks Float?
  date         DateTime
  time         String?
  duration     Int?
  hall         String?
  syllabus     String?
  instructions String?
  status       TestStatus     @default(DRAFT)
  createdBy    Int
  isDeleted    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  publishedAt  DateTime?
  scoresLocked Boolean        @default(false)
  teacherId    Int?
  reminders    TestReminder[]
  scores       TestScore[]
  batch        Batch          @relation(fields: [batchId], references: [id])
  teacher      User?          @relation("TeacherTests", fields: [teacherId], references: [id])

  @@index([batchId])
  @@index([teacherId])
  @@index([batchId, date])
  @@index([status, isDeleted])
  @@index([isDeleted, date])
  @@map("tests")
}

model TestScore {
  id            Int         @id @default(autoincrement())
  testId        Int
  studentId     Int
  marksObtained Float
  percentage    Float
  grade         String?
  status        ScoreStatus @default(PASS)
  remarks       String?
  uploadedBy    Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  student       Student     @relation(fields: [studentId], references: [id])
  test          Test        @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, studentId])
  @@index([testId])
  @@index([studentId])
  @@index([testId, marksObtained])
  @@map("test_scores")
}

model TestReminder {
  id        Int      @id @default(autoincrement())
  testId    Int
  userId    Int
  createdAt DateTime @default(now())
  test      Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, userId])
  @@index([testId])
  @@index([userId])
  @@map("test_reminders")
}

model InstagramAccount {
  id                Int              @id @default(autoincrement())
  userId            Int              @unique
  igUserId          String           @unique
  username          String
  profilePictureUrl String?
  accessToken       String
  tokenExpiresAt    DateTime?
  followersCount    Int?
  mediaCount        Int?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  automationRules   AutomationRule[]
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("instagram_accounts")
}

model AutomationRule {
  id                 Int                  @id @default(autoincrement())
  instagramAccountId Int
  mediaId            String
  mediaUrl           String?
  mediaCaption       String?
  mediaType          String?
  triggerKeyword     String
  dmMessage          String
  dmType             DmType               @default(TEXT)
  dmButtons          Json?
  autoReplyComment   Boolean              @default(false)
  autoReplyText      String?
  status             AutomationRuleStatus @default(ACTIVE)
  dmsSentCount       Int                  @default(0)
  isFollowGated      Boolean              @default(false)
  unfollowedMessage  String?
  lastTriggeredAt    DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  logs               AutomationLog[]
  instagramAccount   InstagramAccount     @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@index([instagramAccountId])
  @@index([mediaId])
  @@index([instagramAccountId, mediaId, triggerKeyword])
  @@map("automation_rules")
}

model AutomationLog {
  id                Int            @id @default(autoincrement())
  ruleId            Int
  commenterId       String
  commenterUsername String?
  commentText       String
  dmStatus          DmStatus       @default(SENT)
  errorMessage      String?
  createdAt         DateTime       @default(now())
  rule              AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([commenterId])
  @@map("automation_logs")
}

model TeacherProfile {
  id                Int      @id @default(autoincrement())
  userId            Int      @unique
  phone             String?
  gender            String?
  qualification     String?
  university        String?
  experience        Int?
  workTimingFrom    String?
  workTimingTo      String?
  primarySubjects   String[]
  secondarySubjects String[]
  bio               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  avatarUrl         String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("teacher_profiles")
}

model Doubt {
  id          Int          @id @default(autoincrement())
  title       String
  description String
  subject     String?
  studentId   Int
  batchId     Int
  status      DoubtStatus  @default(OPEN)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  replies     DoubtReply[]
  batch       Batch        @relation(fields: [batchId], references: [id])
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([batchId])
  @@index([status])
  @@index([batchId, status])
  @@map("doubts")
}

model DoubtReply {
  id        Int      @id @default(autoincrement())
  doubtId   Int
  userId    Int
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  doubt     Doubt    @relation(fields: [doubtId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@index([doubtId])
  @@map("doubt_replies")
}

model ResourceStar {
  id           Int      @id @default(autoincrement())
  studentId    Int
  /// "note" | "study_material" | "video"
  resourceType String
  resourceId   Int
  createdAt    DateTime @default(now())
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, resourceType, resourceId])
  @@index([studentId])
  @@map("resource_stars")
}

model DeviceToken {
  id        Int            @id @default(autoincrement())
  userId    Int
  token     String         @unique
  platform  DevicePlatform @default(EXPO)
  createdAt DateTime       @default(now())
  lastUsed  DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("device_tokens")
}

model AppSettings {
  id                 Int      @id @default(1)
  teacherPermissions Json     @default("{\"canViewFees\": false, \"canExportData\": false, \"canUploadNotes\": true, \"canUploadVideos\": false, \"canViewAnalytics\": false, \"canManageLectures\": true, \"canManageAssignments\": true, \"canSendAnnouncements\": true, \"canManageStudyMaterials\": false}")
  updatedAt          DateTime @updatedAt
  classAddress       String   @default("")
  classEmail         String   @default("")
  className          String   @default("My Coaching Class")
  classPhone         String   @default("")
  classWebsite       String   @default("")

  @@map("app_settings")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum AnnouncementCategory {
  GENERAL
  EXAM
  HOLIDAY
  LECTURE
  EVENT
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum SubmissionType {
  FILE_UPLOAD
  TEXT_ENTRY
  BOTH
}

enum AssignmentStatus {
  DRAFT
  PUBLISHED
}

enum StudyMaterialType {
  DOCUMENT
  VIDEO
  NOTES
  SLIDES
  WORKSHEET
}

enum MaterialStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
}

enum UserRoles {
  ADMIN
  TEACHER
  STUDENT
}

enum AttendanceMethod {
  MANUAL
  QR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
}

enum YoutubeVideoVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
  ONLINE
}

enum FeeFrequency {
  MONTHLY
  QUARTERLY
  SEMI_ANNUAL
  ANNUAL
  ONE_TIME
}

enum LectureStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TestType {
  UNIT_TEST
  MIDTERM
  FINAL
  QUIZ
  PRACTICE
}

enum TestStatus {
  DRAFT
  SCHEDULED
  ONGOING
  COMPLETED
  PUBLISHED
}

enum ScoreStatus {
  PASS
  FAIL
  ABSENT
}

enum AutomationRuleStatus {
  ACTIVE
  PAUSED
}

enum DmStatus {
  SENT
  FAILED
  RATE_LIMITED
}

enum DmType {
  TEXT
  TEMPLATE
}

enum DoubtStatus {
  OPEN
  ANSWERED
  RESOLVED
}

enum DevicePlatform {
  EXPO
  IOS
  ANDROID
