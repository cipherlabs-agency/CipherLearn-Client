// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @unique @default(autoincrement())
  name     String
  email    String    @unique
  password String
  role     UserRoles @default(TEACHER)

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())
}

model Student {
  id         Int      @unique @default(autoincrement())
  firstname  String
  middlename String
  lastname   String
  fullname   String
  email      String   @unique
  dob        String
  batchId    Int?
  attendance Json?
  address    String?
  isDeleted  Boolean?
  deletedBy  String?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())
}

model Batch {
  id            Int      @unique @default(autoincrement())
  name          String
  totalStudents Int?
  timings       Json?
  isDeleted     Boolean?
  deletedBy     String?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())
}

enum UserRoles {
  ADMIN
  TEACHER
  STUDENT
}
