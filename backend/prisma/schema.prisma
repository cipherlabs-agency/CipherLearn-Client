// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       Int       @id @default(autoincrement())
  name     String
  email    String    @unique
  password String
  role     UserRoles @default(STUDENT)

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@map("users")
}

model Student {
  id         Int      @id @default(autoincrement())
  firstname  String
  middlename String
  lastname   String
  fullname   String
  email      String   @unique
  dob        String
  batchId    Int?
  batch      Batch?   @relation(fields: [batchId], references: [id])
  attendance Json?
  address    String?
  isDeleted  Boolean? @default(false)
  deletedBy  String?

  updatedAt   DateTime?    @updatedAt
  createdAt   DateTime?    @default(now())
  attendances Attendance[]

  @@index([batchId])
  @@map("students")
}

model Batch {
  id            Int      @id @default(autoincrement())
  name          String
  totalStudents Int?
  timings       Json?
  isDeleted     Boolean? @default(false)
  deletedBy     String?

  students Student[]
  sheets   AttendanceSheet[]

  updatedAt   DateTime?    @updatedAt
  createdAt   DateTime?    @default(now())
  attendances Attendance[]

  @@map("batches")
}

model AttendanceSheet {
  id         Int          @id @default(autoincrement())
  batchId    Int
  batch      Batch        @relation(fields: [batchId], references: [id])
  month      String
  year       String
  attendance Attendance[]

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([batchId, year, month])
  @@index([batchId, year, month])
  @@map("attendance_sheets")
}

model Attendance {
  id         Int              @id @default(autoincrement())
  studentId  Int
  student    Student          @relation(fields: [studentId], references: [id])
  batchId    Int
  batch      Batch            @relation(fields: [batchId], references: [id])
  date       DateTime         @default(now())
  time       String?
  markedBy   String?
  markedById Int?
  method     AttendanceMethod @default(MANUAL)
  status     AttendanceStatus @default(ABSENT)

  attendanceSheet   AttendanceSheet? @relation(fields: [attendanceSheetId], references: [id])
  attendanceSheetId Int?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@unique([studentId, date, batchId])
  @@index([studentId, date])
  @@index([batchId, date])
  @@index([attendanceSheetId])
  @@map("attendances")
}

model YoutubeVideo {
  id          Int                     @id @default(autoincrement())
  title       String
  description String?
  url         String                  @unique
  visibility  YoutubeVideoVisibility? @default(PRIVATE)
  category    String?
  batchId     Int
  isDeleted   Boolean?                @default(false)
  deletedBy   String?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@map("youtube_videos")
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String[]
  batchId   Int
  category  String?
  isDeleted Boolean? @default(false)
  deletedBy String?
  deletedAt DateTime?

  updatedAt DateTime? @updatedAt
  createdAt DateTime? @default(now())

  @@map("notes")
}

enum UserRoles {
  ADMIN
  TEACHER
  STUDENT
}

enum AttendanceMethod {
  MANUAL
  QR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum YoutubeVideoVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}
