# ─────────────────────────────────────────────────────────────────────────────
# CipherLearn Client Backend — Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# ── APPLICATION ───────────────────────────────────────────────────────────────
APP_PORT=5000
APP_HOST=0.0.0.0
NODE_ENV=production
# Frontend URL — used for CORS. Must match the exact origin the browser uses.
CLIENT_URL=https://cipherlearn-{slug}.vercel.app
# Bcrypt salt rounds — REQUIRED, no default. Must be a positive integer.
SALT=10
# Comma-separated list of emails allowed to sign up as ADMIN.
# CRITICAL: if empty, no admin can be created.
ADMIN_EMAILS=owner@classname.com

# ── DATABASE ──────────────────────────────────────────────────────────────────
# Full Aiven PostgreSQL connection URI — use this (individual parts are ignored)
DB_URL=postgresql://user:password@host:port/database?sslmode=require

# ── JWT & AUTHENTICATION ──────────────────────────────────────────────────────
# CRITICAL: Change from the default. Use: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_random_secret
JWT_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
# Separate secret for QR attendance tokens (optional — falls back to JWT_SECRET)
QR_SECRET=change_me_to_a_different_random_secret

# ── ACCOUNT SECURITY ──────────────────────────────────────────────────────────
ACCOUNT_LOCKOUT_MAX_FAILED=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=30
OTP_EXPIRY_MINUTES=10

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_PASSWORD_RESET_MAX=3
RATE_LIMIT_PASSWORD_RESET_WINDOW_MS=3600000

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
# Used for: student forgot-password OTP, account registration, admin password reset
# Get API key at: https://resend.com — free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_your_api_key_here
# Must be a verified domain in your Resend account (or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=CipherLearn

# ── FILE STORAGE (Cloudinary) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── CLASS BRANDING ────────────────────────────────────────────────────────────
# Set by the admin portal at provision time — mirrors NEXT_PUBLIC_* on the frontend
CLASS_NAME=CipherLearn
CLASS_LOGO_URL=
PRIMARY_COLOR=#0F766E
ACCENT_COLOR=#F59E0B

# ── FEATURE FLAGS ─────────────────────────────────────────────────────────────
# Set to "false" to disable a feature. Defaults to enabled (any other value).
FEATURE_QR_ATTENDANCE=true
FEATURE_FEES=true
FEATURE_ASSIGNMENTS=true
FEATURE_STUDY_MATERIALS=true
FEATURE_ANNOUNCEMENTS=true
FEATURE_VIDEOS=true

# ── INSTAGRAM AUTOMATION (optional) ──────────────────────────────────────────
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
INSTAGRAM_REDIRECT_URI=

# ── BETTER STACK (Logtail) ───────────────────────────────────────────────────
# Ships error & warn logs to Better Stack for centralised monitoring.
# Get a source token at: https://betterstack.com → Sources → Connect source
LOGTAIL_SOURCE_TOKEN=
# Unique ID for this deployment (used in every log entry)
INSTANCE_ID=cipherlearn-prod
# Human‑readable name shown in Better Stack dashboard
INSTANCE_NAME=CipherLearn Production
