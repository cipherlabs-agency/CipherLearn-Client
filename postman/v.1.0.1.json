							"name": "Generate QR Code",
							"event": [
								{
									"listen": "test",
									"script": {
										"exec": [
											"var jsonData = pm.response.json();",
											"if (jsonData.success && jsonData.data && jsonData.data.qrData) {",
											"    pm.environment.set(\"qrData\", jsonData.data.qrData);",
											"    console.log(\"QR Data saved for scanning\");",
											"}",
											"",
											"pm.test(\"QR code generated successfully\", function () {",
											"    pm.response.to.have.status(200);",
											"});"
										],
										"type": "text/javascript"
