{
	"info": {
		"_postman_id": "cipherlearn-app-api-v1.0.2",
		"name": "CipherLearn App API v1.0.2",
		"version": "1.0.2",
		"description": "Complete API collection for CipherLearn Mobile App (Student/Teacher).\n\nIncludes all App API endpoints:\n- App Auth (enrollment check, login, password setup, token refresh)\n- Profile & Dashboard\n- Daily Timetable (lectures/schedule)\n- Tests & Exams (upcoming, complete, results, performance)\n- Attendance\n- Assignments (submit with Cloudinary upload, 25MB/file, note field, status filter)\n- Announcements (category filter, search, pagination, detail with attachments & metadata)\n- Notifications (preference management with quiet hours)\n- Resources (videos, notes, study materials)\n- Fees (receipts, summary)\n\n**Security Headers applied on all requests:**\n- Authorization: Bearer <appToken>\n- Content-Type: application/json (or multipart/form-data for uploads)\n\n**Rate Limits:**\n- Auth endpoints: 5 req/15min (login), 3 req/hr (password reset)\n- File uploads: 10 uploads/5min per IP\n- General reads: 120 req/min per IP\n- Token refresh: 10 req/min per IP\n\n**Caching:**\n- Announcement list: 3 min (category/search/page scoped)\n- Announcement detail: 5 min per id\n- Notification preferences: 10 min per student\n- Fee structures: 60 min per batch\n- Attendance: 2 min\n\n**Setup:**\n1. Import this collection into Postman\n2. Create environment with baseUrl = http://localhost:5000/api\n3. Run 'App Login' first to auto-set appToken\n4. Use student credentials for student-only routes\n\n**Base URL:** http://localhost:5000/api",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:5000/api",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "App Auth",
			"description": "Student/Teacher mobile app authentication.\n\nRate limits:\n- Login: 5 attempts per 15 min per IP\n- Password reset: 3 requests per hour per IP\n- Enrollment check: 10 per minute per IP\n- Token refresh: 10 per minute per IP",
			"item": [
				{
					"name": "Check Enrollment",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"email\": \"student@example.com\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/auth/check-enrollment", "host": ["{{baseUrl}}"], "path": ["app", "auth", "check-enrollment"]},
						"description": "Check if a student is enrolled before allowing password setup.\n\nRate limit: 10 req/min per IP"
					},
					"response": []
				},
				{
					"name": "Setup Password",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"email\": \"student@example.com\",\n    \"password\": \"Student@123\",\n    \"confirmPassword\": \"Student@123\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/auth/setup-password", "host": ["{{baseUrl}}"], "path": ["app", "auth", "setup-password"]},
						"description": "First-time password setup for enrolled students."
					},
					"response": []
				},
				{
					"name": "App Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.success && jsonData.data) {",
									"    if (jsonData.data.token) {",
									"        pm.environment.set('appToken', jsonData.data.token);",
									"        console.log('App token set successfully');",
									"    }",
									"    if (jsonData.data.user) {",
									"        pm.environment.set('appUserId', jsonData.data.user.id);",
									"        pm.environment.set('appUserRole', jsonData.data.user.role);",
									"    }",
									"}",
									"pm.test('Login successful', function () {",
									"    pm.response.to.have.status(200);",
									"    pm.expect(jsonData.success).to.be.true;",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"email\": \"student@example.com\",\n    \"password\": \"Student@123\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/auth/login", "host": ["{{baseUrl}}"], "path": ["app", "auth", "login"]},
						"description": "Student/Teacher login. Token auto-saved to appToken env variable.\n\nRate limit: 5 attempts per 15 min per IP\nSecurity: Account locked after 5 failed attempts"
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["app", "auth", "refresh-token"]},
						"description": "Refresh JWT token before expiry.\n\nRate limit: 10 req/min per IP"
					},
					"response": []
				},
				{
					"name": "Forgot Password",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"email\": \"student@example.com\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["app", "auth", "forgot-password"]},
						"description": "Request password reset OTP via email.\n\nRate limit: 3 req/hr per IP"
					},
					"response": []
				},
				{
					"name": "Verify OTP",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"email\": \"student@example.com\",\n    \"otp\": \"123456\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/auth/verify-otp", "host": ["{{baseUrl}}"], "path": ["app", "auth", "verify-otp"]},
						"description": "Verify the OTP sent to email for password reset."
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"email\": \"student@example.com\",\n    \"otp\": \"123456\",\n    \"newPassword\": \"NewPassword@123\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["app", "auth", "reset-password"]},
						"description": "Reset password using verified OTP."
					},
					"response": []
				},
				{
					"name": "Get Me",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/auth/me", "host": ["{{baseUrl}}"], "path": ["app", "auth", "me"]},
						"description": "Get current authenticated user profile."
					},
					"response": []
				},
				{
					"name": "App Logout",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/auth/logout", "host": ["{{baseUrl}}"], "path": ["app", "auth", "logout"]},
						"description": "Logout and blacklist the current token. Token is invalidated immediately."
					},
					"response": []
				}
			]
		},
		{
			"name": "Profile",
			"description": "Student profile (student-only)",
			"item": [
				{
					"name": "Get My Profile",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/profile", "host": ["{{baseUrl}}"], "path": ["app", "profile"]},
						"description": "Get full student profile with batch details.\n\nCache: 5 min"
					},
					"response": []
				}
			]
		},
		{
			"name": "Dashboard",
			"description": "App dashboard data (student + teacher)",
			"item": [
				{
					"name": "Get Dashboard",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/dashboard", "host": ["{{baseUrl}}"], "path": ["app", "dashboard"]},
						"description": "Get dashboard overview. Different content for students vs teachers."
					},
					"response": []
				},
				{
					"name": "Today's Lectures",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/dashboard/today-lectures", "host": ["{{baseUrl}}"], "path": ["app", "dashboard", "today-lectures"]},
						"description": "Get today's lecture schedule for the dashboard."
					},
					"response": []
				},
				{
					"name": "Quick Access",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/dashboard/quick-access", "host": ["{{baseUrl}}"], "path": ["app", "dashboard", "quick-access"]},
						"description": "Get quick access items for dashboard."
					},
					"response": []
				}
			]
		},
		{
			"name": "Lectures (Timetable)",
			"description": "Daily timetable / lecture schedule",
			"item": [
				{
					"name": "Get My Schedule (Today)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/lectures/my-schedule", "host": ["{{baseUrl}}"], "path": ["app", "lectures", "my-schedule"]},
						"description": "Today's schedule. Returns: date, totalClasses, lectures (title, teacher, startTime, endTime, room, status: FINISHED/ONGOING/UPCOMING), nextClass with countdown."
					},
					"response": []
				},
				{
					"name": "Get My Schedule (Specific Date)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/lectures/my-schedule?date=2026-02-15",
							"host": ["{{baseUrl}}"],
							"path": ["app", "lectures", "my-schedule"],
							"query": [{"key": "date", "value": "2026-02-15", "description": "YYYY-MM-DD format"}]
						},
						"description": "Schedule for a specific date."
					},
					"response": []
				},
				{
					"name": "Get Lecture Detail",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/lectures/1", "host": ["{{baseUrl}}"], "path": ["app", "lectures", "1"]},
						"description": "Single lecture detail: description, notes, status."
					},
					"response": []
				},
				{
					"name": "Add Post-Lecture Notes (Teacher)",
					"request": {
						"method": "PUT",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}, {"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"notes\": \"Covered chapters 3-4. Students need to review quadratic formula.\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/lectures/1/notes", "host": ["{{baseUrl}}"], "path": ["app", "lectures", "1", "notes"]},
						"description": "Teacher adds post-lecture notes."
					},
					"response": []
				},
				{
					"name": "Mark Lecture Complete (Teacher)",
					"request": {
						"method": "PUT",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/lectures/1/complete", "host": ["{{baseUrl}}"], "path": ["app", "lectures", "1", "complete"]},
						"description": "Teacher marks a lecture as completed."
					},
					"response": []
				}
			]
		},
		{
			"name": "Tests & Exams",
			"description": "Tests, scores, and performance analytics",
			"item": [
				{
					"name": "Get All Tests",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests", "host": ["{{baseUrl}}"], "path": ["app", "tests"]},
						"description": "All tests for the student. Returns: title, subject, testType, date, time, syllabus, daysUntil."
					},
					"response": []
				},
				{
					"name": "Get Upcoming Tests",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests?status=upcoming", "host": ["{{baseUrl}}"], "path": ["app", "tests"], "query": [{"key": "status", "value": "upcoming"}]},
						"description": "Filter: upcoming tests only (SCHEDULED/ONGOING)."
					},
					"response": []
				},
				{
					"name": "Get Completed Tests",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests?status=complete", "host": ["{{baseUrl}}"], "path": ["app", "tests"], "query": [{"key": "status", "value": "complete"}]},
						"description": "Filter: completed tests (COMPLETED/PUBLISHED)."
					},
					"response": []
				},
				{
					"name": "Get Results (Published)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests?status=results", "host": ["{{baseUrl}}"], "path": ["app", "tests"], "query": [{"key": "status", "value": "results"}]},
						"description": "Filter: published results with 'VIEW SCORE' button."
					},
					"response": []
				},
				{
					"name": "Get Test Detail (Student)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests/1", "host": ["{{baseUrl}}"], "path": ["app", "tests", "1"]},
						"description": "Test details: type, subject, date, time, duration, totalMarks, hall, syllabus, instructions, daysUntil. If PUBLISHED: includes myScore (marksObtained, percentage, grade, status, remarks, checkedBy)."
					},
					"response": []
				},
				{
					"name": "Get Performance Analytics (Student)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests/performance", "host": ["{{baseUrl}}"], "path": ["app", "tests", "performance"]},
						"description": "Student performance analytics: overallAverage, totalTests, passed, failed, highestScore, lowestScore, subjectWise averages, trend over time."
					},
					"response": []
				},
				{
					"name": "Get Batch Tests (Teacher)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests/batch/1", "host": ["{{baseUrl}}"], "path": ["app", "tests", "batch", "1"]},
						"description": "Teacher view: all tests for a specific batch."
					},
					"response": []
				},
				{
					"name": "Get Test Scores (Teacher)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/tests/1/scores", "host": ["{{baseUrl}}"], "path": ["app", "tests", "1", "scores"]},
						"description": "Teacher view: all student scores for a test, sorted by marks descending."
					},
					"response": []
				}
			]
		},
		{
			"name": "Attendance",
			"description": "Student attendance records, history, and calendar",
			"item": [
				{
					"name": "Get My Attendance",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/attendance", "host": ["{{baseUrl}}"], "path": ["app", "attendance"]},
						"description": "Student attendance performance: totalClasses, present, absent, late, attendancePercentage, statusLabel, monthlyBreakdown, recentAttendance.\n\nCache: 2 min"
					},
					"response": []
				},
				{
					"name": "Get Attendance History",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/attendance/history?month=2&year=2026&status=PRESENT",
							"host": ["{{baseUrl}}"],
							"path": ["app", "attendance", "history"],
							"query": [
								{"key": "month", "value": "2", "description": "Month (1-12). Optional."},
								{"key": "year", "value": "2026", "description": "Year. Optional."},
								{"key": "status", "value": "PRESENT", "description": "PRESENT | ABSENT | LATE. Optional."}
							]
						},
						"description": "Filtered attendance history. All params optional."
					},
					"response": []
				},
				{
					"name": "Get Attendance Calendar",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/attendance/calendar?month=2&year=2026",
							"host": ["{{baseUrl}}"],
							"path": ["app", "attendance", "calendar"],
							"query": [
								{"key": "month", "value": "2", "description": "Month (1-12). Required."},
								{"key": "year", "value": "2026", "description": "Year. Required."}
							]
						},
						"description": "Per-day attendance for a month. Returns array of {date, status, subject}.\n\nCache: 2 min"
					},
					"response": []
				}
			]
		},
		{
			"name": "Assignments",
			"description": "Assignment slots, submissions with Cloudinary file upload, and teacher reviews.\n\n**Changes in v1.0.2:**\n- Submit: 25MB per file (was 10MB), Cloudinary storage (no local disk)\n- Submit: optional `note` field (text note from student)\n- List: `?status=pending|completed` for Pending/Completed tabs\n- Submission response now includes `note`, `publicId` in files",
			"item": [
				{
					"name": "Get My Stats",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/assignments/stats", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "stats"]},
						"description": "Student assignment statistics: total, pending, accepted, rejected counts."
					},
					"response": []
				},
				{
					"name": "Get All Assignments (Student — All)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/assignments", "host": ["{{baseUrl}}"], "path": ["app", "assignments"]},
						"description": "All assignments for the student's batch with submission status.\n\nResponse includes: id, title, subject, dueDate, isOverdue, daysRemaining, hasSubmitted, submissionStatus, submission (if exists, includes note field)."
					},
					"response": []
				},
				{
					"name": "Get Assignments — Pending Tab",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/assignments?status=pending",
							"host": ["{{baseUrl}}"],
							"path": ["app", "assignments"],
							"query": [{"key": "status", "value": "pending", "description": "Only assignments not yet submitted (Pending tab)"}]
						},
						"description": "Student Pending tab: assignments not yet submitted.\n\nStatus badges: Overdue (red), Pending (yellow)\nDeadline display: 'Overdue' | 'Due Tomorrow, 11:59 PM' | 'Due Mar 05 (7 days)'"
					},
					"response": []
				},
				{
					"name": "Get Assignments — Completed Tab",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/assignments?status=completed",
							"host": ["{{baseUrl}}"],
							"path": ["app", "assignments"],
							"query": [{"key": "status", "value": "completed", "description": "Only submitted assignments (Completed tab)"}]
						},
						"description": "Student Completed tab: submitted assignments.\n\nStatus badge: Completed (green)\nShows submission timestamp"
					},
					"response": []
				},
				{
					"name": "Get All Assignments (Teacher — with stats)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/assignments?batchId=1&page=1&limit=20&includeExpired=true",
							"host": ["{{baseUrl}}"],
							"path": ["app", "assignments"],
							"query": [
								{"key": "batchId", "value": "1", "description": "Filter by batch. Optional."},
								{"key": "page", "value": "1"},
								{"key": "limit", "value": "20"},
								{"key": "includeExpired", "value": "true", "description": "Include past due assignments"}
							]
						},
						"description": "Teacher/Admin view: all assignments with submission stats (total, pending, accepted, rejected)."
					},
					"response": []
				},
				{
					"name": "Get Assignment Detail",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/assignments/1", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "1"]},
						"description": "Assignment detail: subject badge, title, dueDate, teacher (createdBy), instructions, attached files (Cloudinary URLs + video links).\n\nFor students: includes their submission with files, note, status, feedback."
					},
					"response": []
				},
				{
					"name": "Submit Assignment (Student)",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"body": {
							"mode": "formdata",
							"formdata": [
								{"key": "files", "type": "file", "src": "", "description": "Upload 1-5 files. Max 25MB each. PDF, Word, Excel, PPT, images, ZIP accepted."},
								{"key": "note", "value": "Please find my completed worksheet attached. I used the quadratic formula method.", "type": "text", "description": "Optional text note (max 1000 chars)"}
							]
						},
						"url": {"raw": "{{baseUrl}}/app/assignments/1/submit", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "1", "submit"]},
						"description": "Student submits assignment.\n\n**Upload specs (v1.0.2):**\n- Storage: Cloudinary (submissions/ folder)\n- Max per file: 25 MB\n- Max files: 5\n- Types: PDF, Word, Excel, PPT, images (JPEG/PNG/GIF/WebP), ZIP, TXT\n- Security: MIME type validation + magic number (file signature) check\n\n**Rate limit:** 10 uploads per 5 min per IP\n\nRe-submission allowed if previous status is REJECTED."
					},
