							]
						},
						"url": {"raw": "{{baseUrl}}/app/assignments/1/submit", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "1", "submit"]},
						"description": "Student submits assignment with optional file attachments (max 5 files)."
					},
					"response": []
				},
				{
					"name": "Get My Submission",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/assignments/1/my-submission", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "1", "my-submission"]},
						"description": "Get student's own submission for an assignment slot."
					},
					"response": []
				},
				{
					"name": "Get Slot Submissions (Teacher)",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/assignments/1/submissions", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "1", "submissions"]},
						"description": "Teacher/Admin: get all submissions for an assignment slot."
					},
					"response": []
				},
				{
					"name": "Get Submission Detail",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/assignments/submissions/1", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "submissions", "1"]},
						"description": "Get detailed submission with attachments."
					},
					"response": []
				},
				{
					"name": "Review Submission (Teacher)",
					"request": {
						"method": "PUT",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}, {"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n    \"marks\": 85,\n    \"feedback\": \"Good work! Well structured approach.\",\n    \"status\": \"REVIEWED\"\n}"},
						"url": {"raw": "{{baseUrl}}/app/assignments/submissions/1/review", "host": ["{{baseUrl}}"], "path": ["app", "assignments", "submissions", "1", "review"]},
						"description": "Teacher reviews and grades a student submission."
					},
					"response": []
				}
			]
		},
		{
			"name": "Announcements",
			"description": "View announcements",
			"item": [
				{
					"name": "Get Announcements",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {"raw": "{{baseUrl}}/app/announcements", "host": ["{{baseUrl}}"], "path": ["app", "announcements"]},
						"description": "Get all active announcements for the app user."
					},
					"response": []
				}
			]
		},
		{
			"name": "Resources",
			"description": "Study resources: videos, notes, materials",
			"item": [
				{
					"name": "Get Videos",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/resources/videos?search=&category=",
							"host": ["{{baseUrl}}"],
							"path": ["app", "resources", "videos"],
							"query": [
								{"key": "search", "value": "", "description": "Search by title. Optional."},
								{"key": "category", "value": "", "description": "Filter by category. Optional."}
							]
						},
						"description": "Get YouTube videos for the student's batch. Supports ?search= and ?category= filters."
					},
					"response": []
				},
				{
					"name": "Get Notes",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{appToken}}"}],
						"url": {
							"raw": "{{baseUrl}}/app/resources/notes?search=&category=",
							"host": ["{{baseUrl}}"],
							"path": ["app", "resources", "notes"],
